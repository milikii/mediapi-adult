# Dedicated adult downloader configuration. Do not point this at the PT/viewing downloader.
ADULT_DOWNLOADER_TYPE=qbittorrent  # or transmission

# qBittorrent
ADULT_QB_URL=http://localhost:8081
ADULT_QB_USERNAME=admin
ADULT_QB_PASSWORD=your_password

# Transmission
ADULT_TR_URL=http://localhost:9092
ADULT_TR_USERNAME=transmission
ADULT_TR_PASSWORD=your_password

# Local state for active task registry and completed-history dedupe.
ADULT_STATE_DIR=/private/adult/.mediapi-adult-state

# Category import targets. Chat, Pi session entries, and state should store aliases, not full paths.
ADULT_IMPORT_TARGET_CENSORED=/private/adult/censored
ADULT_IMPORT_TARGET_UNCENSORED=/private/adult/uncensored
ADULT_IMPORT_TARGET_NO_CODE=/private/adult/no-code

# Background monitor
ADULT_MONITOR_ENABLED=true
ADULT_MONITOR_INTERVAL_SECONDS=60

# Enabled public BT sites. Do not configure Prowlarr or PT indexers here.
ADULT_ENABLED_SITES=sukebei

# Site configuration
SUKEBEI_BASE_URL=https://sukebei.nyaa.si
JAVBUS_BASE_URL=https://www.javbus.com
JAVLIBRARY_BASE_URL=https://www.javlibrary.com

# Legacy compatibility only. New workflow cleans up after import instead of seeding for retention days.
# ADULT_RETENTION_DAYS=0

# Optional translation service
# TRANSLATE_API_KEY=your_translate_api_key
